<Window x:Class="SnakeGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snake" Height="600" Width="1142"
        Background="#1a1a1a" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button" x:Key="MenuButton">
            <Setter Property="Width" Value="180"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,8,0,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#4caf50"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#4caf50"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4caf50"/>
                                <Setter Property="Foreground" Value="#1a1a1a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#388e3c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <!-- Dark grey gradient background -->
       

        <!-- Grid lines drawn in code-behind -->
        <Canvas x:Name="BgCanvas" Opacity="0.12" Background="White"/>

        <!-- Game Canvas (hidden until game starts) -->
        <Canvas x:Name="GameCanvas" Visibility="Collapsed" />

        <!-- Menu -->
        <StackPanel x:Name="MenuPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <TextBlock Text="GIGYO"
                       Foreground="#4caf50"
                       FontSize="64"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>
            <Button Content="Játék"        Style="{StaticResource MenuButton}" Click="StartGame_Click"/>
            <Button Content="Ranglista" Style="{StaticResource MenuButton}" Click="HighScores_Click"/>
            <Button Content="Kilépés"        Style="{StaticResource MenuButton}" Click="Quit_Click"/>
        </StackPanel>
    </Grid>
</Window>